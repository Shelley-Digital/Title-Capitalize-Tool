<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SEO Title Generator | Ahrefs Clone Dark‑Purple Theme</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        :root {
            --bg-main: #090714;
            --bg-card: #140f2b;
            --primary-purple: #9d4edd;
            --purple-light: #c77dff;
            --purple-dark: #5a189a;
            --text-white: #f3f3ff;
            --text-gray: #b9b6d8;
            --border-color: #381b61;
        }
        body {
            background-color: var(--bg-main);
            color: var(--text-gray);
            line-height: 1.6;
            padding: 40px 16px;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
        }
        h1 {
            color: var(--text-white);
            font-size: 36px;
            text-align: center;
            margin-bottom: 12px;
        }
        .page-desc {
            text-align: center;
            font-size: 17px;
            margin-bottom: 40px;
        }
        .input-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 28px;
            margin-bottom: 30px;
        }
        label {
            display: block;
            color: var(--text-white);
            font-weight: 500;
            margin-bottom: 10px;
            font-size: 16px;
        }
        input, textarea {
            width: 100%;
            background: #0e0a20;
            border: 1px solid var(--border-color);
            color: var(--text-white);
            padding: 14px;
            border-radius: 8px;
            font-size: 16px;
        }
        input:focus, textarea:focus {
            outline: none;
            border-color: var(--primary-purple);
            box-shadow: 0 0 0 3px rgba(157,78,221,0.25);
        }
        .row-two {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap:20px;
            margin-top:20px;
        }
        .btn-generate {
            width:100%;
            margin-top:24px;
            background-color: var(--purple-dark);
            color:#fff;
            font-size:16px;
            font-weight:500;
            border: none;
            padding:14px;
            border-radius:8px;
            cursor: pointer;
            transition: 0.25s;
        }
        .btn-generate:hover {
            background-color: var(--primary-purple);
        }
        .result-heading{
            color: var(--purple-light);
            font-size:22px;
            margin:40px 0 20px;
        }
        .title-item{
            background: var(--bg-card);
            border:1px solid var(--border-color);
            padding:16px;
            border-radius:8px;
            margin-bottom:12px;
            display:flex;
            justify-content: space-between;
            align-items:center;
        }
        .title-text{
            color: var(--text-white);
        }
        .copy-btn{
            background: transparent;
            border:1px solid var(--primary-purple);
            color: var(--purple-light);
            padding:6px 12px;
            border-radius:5px;
            cursor:pointer;
        }
        .info-section{
            margin-top:60px;
        }
        .info-section h2{
            color: var(--purple-light);
            margin:30px 0 14px;
        }
        .info-section p, li{
            margin-bottom:12px;
        }
        @media (max-width:640px){
            .row-two{
                grid-template-columns:1fr;
            }
            h1{
                font-size:28px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>SEO Title Generator</h1>
        <p class="page-desc">Create click‑worthy SEO‑optimized title tags for your web‑pages for free.</p>

        <div class="input-card">
            <label>Primary keyword</label>
            <input id="keyword" placeholder="Example: best running shoes">
            <div class="row-two">
                <div>
                    <label>Your brand name</label>
                    <input id="brand" placeholder="Example: Nike">
                </div>
                <div>
                    <label>Tone</label>
                    <input id="tone" placeholder="Professional, Casual, Urgent">
                </div>
            </div>
            <button class="btn-generate" onclick="generateTitles()">Generate Title Tags</button>
        </div>

        <h3 class="result-heading">Generated Title Ideas</h3>
        <div id="resultArea">
        </div>

        <div class="info-section">
            <h2>What is an SEO Title Tag?</h2>
            <p>An SEO title tag (page‑title) is the click‑able headline that shows up inside Google search results. Well‑written titles boost organic click‑through‑rate and rankings.</p>
            <h2>Best Practices for Title‑Tags</h2>
            <ul>
                <li>Keep your title length between 50‑60 characters so Google displays full text.</li>
                <li>Put your main keyword towards the front side of your title.</li>
                <li>Add power‑words to increase click‑through‑rate.</li>
                <li>Include your brand name at the end of the title consistently.</li>
            </ul>
        </div>
    </div>

    <script>
        const resultArea = document.getElementById("resultArea");
        function generateTitles(){
            const keyword = document.getElementById("keyword").value.trim();
            const brand = document.getElementById("brand").value.trim();
            if(!keyword){
                alert("Please fill your primary keyword");
                return;
            }
            const templates = [
                `${keyword} | Expert Reviewed 2026 | ${brand}`,
                `The Ultimate Guide to ${keyword} (Pro Tips) - ${brand}`,
                `${keyword}: Honest Buying Advice You Need - ${brand}`,
                `Top ${keyword} Options Compared by Industry Experts | ${brand}`,
                `Why ${keyword} Matters in 2026 — Complete Overview | ${brand}`
            ];
            resultArea.innerHTML = "";
            templates.forEach((titleStr)=>{
                const div = document.createElement("div");
                div.className = "title-item";
                div.innerHTML = `
                    <span class="title-text">${titleStr}</span>
                    <button class="copy-btn" onclick="copyText('${titleStr}')">Copy</button>
                `;
                resultArea.appendChild(div);
            })
        }
        async function copyText(text){
            await navigator.clipboard.writeText(text);
            alert("Copied to clipboard");
        }
    </script>
</body>
</html>
